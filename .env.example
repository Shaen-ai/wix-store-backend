APP_NAME="3D Store"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Production: APP_URL=https://wixstoreapi.nextechspires.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=store3d
DB_USERNAME=root
DB_PASSWORD=

# Wix App credentials
WIX_APP_ID=YOUR-WIX-APP-ID
WIX_APP_SECRET=YOUR-WIX-APP-SECRET

# CORS – frontend origin (all served from wixstore.nextechspires.com)
# Production:
FRONTEND_WIDGET_URL=https://wixstore.nextechspires.com
FRONTEND_DASHBOARD_URL=https://wixstore.nextechspires.com
FRONTEND_SETTINGS_URL=https://wixstore.nextechspires.com

# Mail via local Postfix SMTP (production host)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@yourdomain.com"
MAIL_FROM_NAME="3D Store"

# PayPal
PAYPAL_SANDBOX=true
# Production:
# PAYPAL_IPN_URL=https://wixstoreapi.nextechspires.com/api/v1/paypal/ipn
# PAYPAL_RETURN_URL=https://wixstore.nextechspires.com/widget/?payment=success
# PAYPAL_CANCEL_URL=https://wixstore.nextechspires.com/widget/?payment=cancelled
PAYPAL_IPN_URL=https://3dstore-api.example.com/api/v1/paypal/ipn
PAYPAL_RETURN_URL=https://3dstore-widget.example.com/?payment=success
PAYPAL_CANCEL_URL=https://3dstore-widget.example.com/?payment=cancelled

# Image-to-3D default provider (per-tenant keys in DB)
IMAGE_TO_3D_PROVIDER=meshy

# FX rates
FX_PROVIDER=exchangerate
FX_CACHE_TTL_MINUTES=60

# File storage
FILESYSTEM_DISK=local
# For S3:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=3dstore-assets

QUEUE_CONNECTION=database
