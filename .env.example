APP_NAME="3D Store"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

CACHE_STORE=file

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=store3d
# DB_USERNAME=root
# DB_PASSWORD=

# Wix App credentials
WIX_APP_ID=
WIX_APP_SECRET=
WIX_3D_STORE_PUBLIC_KEY=

# Dev mode (APP_ENV=local only): use token "dev" to bypass Wix auth
WIX_DEV_INSTANCE_TOKEN=dev
WIX_DEV_INSTANCE_ID=dev-local

# CORS – frontend URLs allowed to call this API
FRONTEND_WIDGET_URL=http://localhost:5174
FRONTEND_DASHBOARD_URL=http://localhost:5176
FRONTEND_SETTINGS_URL=http://localhost:5175

# Mail
MAIL_MAILER=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# PayPal
PAYPAL_SANDBOX=true
PAYPAL_IPN_URL=
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=

# Image-to-3D default provider (per-tenant keys in DB)
IMAGE_TO_3D_PROVIDER=meshy
IMAGE_TO_3D_API_KEY=

# FX rates
FX_PROVIDER=exchangerate
FX_CACHE_TTL_MINUTES=60

# File storage
FILESYSTEM_DISK=local
# For S3:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=3dstore-assets

QUEUE_CONNECTION=database
